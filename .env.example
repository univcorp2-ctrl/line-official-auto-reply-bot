# LINE Developers Console > Messaging API channel
LINE_CHANNEL_SECRET=replace_me
LINE_CHANNEL_ACCESS_TOKEN=replace_me

# Local development only. In production, keep false.
DRY_RUN=false

# rules: YAMLルールのみ / ai: AI中心 / hybrid: ルール優先 + AI
REPLY_MODE=rules
RULES_PATH=app/rules.yml
MAX_REPLY_CHARS=900

# Optional AI replies
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=350
OPENAI_SYSTEM_PROMPT=あなたはLINE公式アカウントの一次対応担当です。短く丁寧に日本語で返信してください。

DATABASE_URL=sqlite:///./data/line_events.db
APP_ENV=development
